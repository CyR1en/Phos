# Deployment: Your site URL for canonical links and sitemap
PUBLIC_SITE_URL=https://yourdomain.com

# Nginx: Internal listen port (default: 8080). Change only if you need nginx
# to bind a different port inside the container (not the Docker mapped port).
# The Docker mapping is controlled by the PORT variable in docker-compose.yml.
LISTEN_PORT=8080

# Admin: Customize admin dashboard password (default: admin)
ADMIN_PASSWORD=change-me

# Optional: Tune hero slideshow
PUBLIC_HERO_INTERVAL=6000
PUBLIC_HERO_OVERLAY_OPACITY=0.2
