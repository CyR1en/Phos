---
import '../styles/global.css'
import Header from '@components/Header.astro'
import Footer from '@components/Footer.astro'
import config from '@content/site-config.json'

export interface Props {
  title: string
  description?: string
  image?: string
  page?: string
}

const { title, description, image, page } = Astro.props

const pageTitle = title ? `${title} — ${config.site.title}` : config.site.title

const siteUrl = import.meta.env.PUBLIC_SITE_URL
const canonical = siteUrl ? `${siteUrl}/${page || ''}` : undefined

const configOg = config.site?.og
const resolveUrl = (path) => siteUrl ? `${siteUrl}${path}` : undefined
const ogImage = image
  ? (image.startsWith('http') ? image : resolveUrl(image))
  : (configOg?.image ? resolveUrl(configOg.image) : undefined)

const ogDescription = description || config.site.description
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title data-config="site.title">{pageTitle}</title>
    <meta name="description" content={ogDescription} data-config="site.description" data-config-attr="content" />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} data-config="site.title" data-config-attr="content" />
    <meta property="og:description" content={ogDescription} data-config="site.description" data-config-attr="content" />
    <meta property="og:site_name" content={config.site.title} />
    <meta property="og:locale" content="en_US" />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && configOg?.imageWidth && <meta property="og:image:width" content={configOg.imageWidth} />}
    {ogImage && configOg?.imageHeight && <meta property="og:image:height" content={configOg.imageHeight} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={ogDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          if (stored === 'light') {
            document.documentElement.classList.remove('dark');
          } else if (stored === 'dark') {
            document.documentElement.classList.add('dark');
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.classList.add('dark');
          }
        } catch(e) {}
      })();
    </script>

    <script is:inline>
      (function() {
        if (document.querySelector('[data-config]') === null) return;
        fetch('/site-config.json', { credentials: 'same-origin' })
          .then(function(r) { return r.ok ? r.json() : null })
          .then(function(cfg) { if (cfg) applyConfig(cfg); })
          .catch(function() {});

        function applyConfig(cfg) {
          var els = document.querySelectorAll('[data-config]');
          for (var i = 0; i < els.length; i++) {
            var el = els[i];
            var path = el.getAttribute('data-config');
            var value = resolve(cfg, path);
            if (value === undefined || value === null) continue;
            if (typeof value === 'object') continue;
            if (el.tagName === 'TITLE') {
              el.textContent = value;
            } else if (el.tagName === 'META') {
              var attr = el.getAttribute('data-config-attr') || 'content';
              el.setAttribute(attr, value);
            } else if (el.tagName === 'A' || el.tagName === 'LINK') {
              var hrefAttr = el.getAttribute('data-config-attr') || 'href';
              el.setAttribute(hrefAttr, value);
            } else {
              el.textContent = value;
            }
          }
        }

        function resolve(obj, path) {
          if (!obj) return undefined;
          var parts = path.split('.');
          var cur = obj;
          for (var i = 0; i < parts.length; i++) {
            if (cur == null) return undefined;
            cur = cur[parts[i]];
          }
          return cur;
        }
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-phos-canvas dark:bg-phos-canvas text-phos-ink dark:text-phos-ink antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.setAttribute('data-visible', '')
            observer.unobserve(entry.target)
          }
        })
      }, { threshold: 0.1 })

      document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el))
    </script>
  </body>
</html>
