---
import BaseLayout from '@layouts/BaseLayout.astro'
import Gallery from '@components/Gallery.astro'
import Lightbox from '@components/Lightbox.astro'
import config from '@content/site-config.json'

export async function getStaticPaths() {
  const manifest = await import('@content/categories.json').then(m => m.default || m)
  const cats = manifest.categories
  return cats.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }))
}

const { category } = Astro.props

const photos = category.photos.map((p) => ({ ...p, category: category.slug }))

const siteUrl = import.meta.env.PUBLIC_SITE_URL || ''
const ogImage = category.coverFull ? `${siteUrl}${category.coverFull}` : undefined
---

<BaseLayout title={category.name} description={category.description} image={ogImage} page={`photos/${category.slug}`}>
  <section class="mx-auto max-w-7xl px-6 pt-24 sm:px-6 lg:px-8">
    <a href="/portfolio/" class="inline-flex items-center gap-1 phos-caption text-phos-body-muted dark:text-phos-body-muted hover:text-phos-ink dark:hover:text-phos-ink transition-colors mb-8">
      <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      All work
    </a>

    <div class="border-b border-phos-hairline dark:border-phos-hairline pb-12">
      <p class="phos-mono-label text-phos-muted dark:text-phos-muted">Category</p>
      <h1 class="mt-4 font-display text-phos-display-product text-phos-ink dark:text-phos-ink">{category.name}</h1>
      {category.description && <p class="mt-6 max-w-2xl phos-body-lg text-phos-body-muted dark:text-phos-body-muted">{category.description}</p>}
      <p class="mt-6 phos-micro text-phos-muted dark:text-phos-muted">{category.photos.length} photo{category.photos.length !== 1 ? 's' : ''}</p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-16 sm:pb-24 sm:px-6 lg:px-8 pt-10">
    <Gallery photos={photos} category={category.slug} />
  </section>

  <Lightbox photos={photos} />
</BaseLayout>
