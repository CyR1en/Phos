---
import BaseLayout from '@layouts/BaseLayout.astro'
import Gallery from '@components/Gallery.astro'
import Lightbox from '@components/Lightbox.astro'
import config from '@content/site-config.json'

export async function getStaticPaths() {
  const manifest = await import('@content/categories.json').then(m => m.default || m)
  const cats = manifest.categories
  return cats.map((cat) => ({
    params: { category: cat.slug },
    props: { category: cat },
  }))
}

const { category } = Astro.props

const photos = category.photos.map((p) => ({ ...p, category: category.slug }))

const siteUrl = import.meta.env.PUBLIC_SITE_URL || ''
const ogImage = category.coverFull ? `${siteUrl}${category.coverFull}` : undefined
---

<BaseLayout title={category.name} description={category.description} image={ogImage} page={`photos/${category.slug}`}>
  <section data-animate class="animate-reveal mx-auto max-w-7xl px-4 pt-12 sm:pt-16 sm:px-6 lg:px-8">
    <a href="/portfolio/" class="inline-flex items-center gap-1 text-sm text-subtle dark:text-subtle-dark hover:text-ink dark:hover:text-ink-dark transition-colors mb-4 sm:mb-6">
      <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Back to portfolio
    </a>

    <div class="mb-6 sm:mb-10">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{category.name}</h1>
      {category.description && <p class="mt-2 text-subtle dark:text-subtle-dark">{category.description}</p>}
      <p class="mt-1 text-sm text-subtle dark:text-subtle-dark">{category.photos.length} photo{category.photos.length !== 1 ? 's' : ''}</p>
    </div>
  </section>

  <section data-animate class="animate-reveal mx-auto max-w-7xl px-4 pb-16 sm:pb-24 sm:px-6 lg:px-8">
    <Gallery photos={photos} category={category.slug} />
  </section>

  <Lightbox photos={photos} />
</BaseLayout>
