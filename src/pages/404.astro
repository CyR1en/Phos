---
import BaseLayout from '@layouts/BaseLayout.astro'
import config from '@content/site-config.json'
---

<BaseLayout title={config.notFound.heading}>
  <section class="mx-auto flex min-h-[80vh] max-w-4xl flex-col items-start justify-center px-6 sm:px-6 lg:px-8">
    <p class="phos-mono-label text-phos-muted dark:text-phos-muted">Error 404</p>
    <h1 class="mt-6 font-display text-phos-hero text-phos-ink dark:text-phos-ink" data-config="notFound.heading">{config.notFound.heading}</h1>
    <p class="mt-6 max-w-2xl phos-body-lg text-phos-body-muted dark:text-phos-body-muted" data-config="notFound.message">{config.notFound.message}</p>
    <a
      href="/"
      class="mt-10 inline-flex items-center rounded-phos-pill bg-phos-primary dark:bg-phos-primary px-6 py-3 phos-button text-phos-canvas dark:text-phos-canvas hover:opacity-90 transition-opacity"
    >
      <span data-config="notFound.button">{config.notFound.button}</span>
      <svg class="ml-2 size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </section>
</BaseLayout>
