---
import BaseLayout from '@layouts/BaseLayout.astro'
import Gallery from '@components/Gallery.astro'
import Lightbox from '@components/Lightbox.astro'

export async function getStaticPaths() {
  let galleries: any[] = []
  try {
    const gals = await import('@content/galleries.json').then(m => m.default || m)
    galleries = gals.galleries || []
  } catch {
    galleries = []
  }

  return galleries.map((gallery) => ({
    params: { gallery: gallery.slug },
    props: { gallery },
  }))
}

const { gallery } = Astro.props

const photos = gallery.photos.map((p: any) => ({ ...p, category: p.category }))

const siteUrl = import.meta.env.PUBLIC_SITE_URL || ''
const ogImage = gallery.coverFull ? `${siteUrl}${gallery.coverFull}` : undefined
---

<BaseLayout title={gallery.name} description={gallery.description} image={ogImage} page={`portfolio/${gallery.slug}`} type="article">
  <section class="pt-24 pb-12">
    <div class="mx-auto max-w-7xl px-6 sm:px-6 lg:px-8">
      <a href="/portfolio/" class="inline-flex items-center gap-1 text-sm text-body-muted hover:text-ink transition-colors mb-8">
        <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Galleries
      </a>

      <div class="border-b border-border pb-12">
        <p class="font-mono text-xs uppercase tracking-wider text-muted">Gallery</p>
        <h1 class="mt-4 font-display text-5xl sm:text-6xl text-ink">{gallery.name}</h1>
        {gallery.description && <p class="mt-6 max-w-2xl text-lg text-body-muted leading-relaxed">{gallery.description}</p>}
        <p class="mt-6 text-xs text-muted">{gallery.photoCount} photo{gallery.photoCount !== 1 ? 's' : ''}</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-16 sm:pb-24 lg:px-8 pt-10">
    <Gallery photos={photos} category={gallery.slug} />
  </section>

  <Lightbox photos={photos} />
</BaseLayout>
