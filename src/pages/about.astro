---
import BaseLayout from '@layouts/BaseLayout.astro'
import config from '@content/site-config.json'
import Plugins from '@components/Plugins.astro'
import CTA from '@components/CTA.astro'

const aboutPhoto = config.about.photographer?.photo || ''
const gear = config.about.gear || {}
const gearLabel = gear.heading || 'My Gear'
const gearList = gear.equipment || []
const hasGear = gearList.length > 0
const bio = config.about.photographer?.bio || ''
const BIO_WORD_LIMIT = 250
const bioWords = bio.split(/\s+/).filter(Boolean)
const bioExceedsLimit = bioWords.length > BIO_WORD_LIMIT
const truncatedBio = bioExceedsLimit ? bioWords.slice(0, BIO_WORD_LIMIT).join(' ') : ''
const remainingBio = bioExceedsLimit ? bioWords.slice(BIO_WORD_LIMIT).join(' ') : ''
const cta = config.about.call_to_action
const ogTitle = config.about?.og_title || 'About'
const ogDescription = config.about?.og_description
---

<BaseLayout title={ogTitle} description={ogDescription}>
  <section data-animate class="animate-reveal flex min-h-[70vh] lg:h-dvh flex-col lg:flex-row overflow-hidden">
    <div class="relative h-[50vh] sm:h-[40vh] lg:h-full w-full lg:w-1/2 shrink-0 overflow-hidden bg-surface">
      {aboutPhoto ? (
        <img
          src={aboutPhoto}
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
          loading="eager"
        />
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-surface to-border" />
      )}
    </div>
    <div class="relative flex-1 overflow-y-auto flex items-center px-6 py-12 sm:py-16 lg:px-12 lg:py-0 xl:px-16">
      <div class="max-w-xl">
        <p class="font-mono text-xs uppercase tracking-wider text-accent">About</p>
        <h1 class="mt-6 font-display text-3xl sm:text-5xl text-ink leading-none" data-config="about.photographer.name">
          {config.about.photographer.name}
        </h1>
        <p class="mt-8 border-l-2 border-accent pl-6 text-lg text-body-muted leading-relaxed" data-config="about.photographer.intro">
          {config.about.photographer.intro}
        </p>
        <div class="mt-10 h-px w-24 bg-border" />
        {bio.trim() && (
          <div class="mt-6 space-y-3" id="bio-container">
            {bioExceedsLimit ? (
              <>
                <div id="bio-truncated" class="space-y-3">
                  {truncatedBio.split('\n\n').filter(Boolean).map((para) => (
                    <p class="text-lg text-body-muted">{para}</p>
                  ))}
                </div>
                <div id="bio-rest" class="hs-collapse hidden overflow-hidden transition-[height] duration-300 space-y-3">
                  {remainingBio.split('\n\n').filter(Boolean).map((para) => (
                    <p class="text-lg text-body-muted">{para}</p>
                  ))}
                </div>
                <button
                  id="bio-toggle"
                  type="button"
                  data-hs-collapse="#bio-rest"
                  aria-expanded="false"
                  aria-controls="bio-rest"
                  class="text-sm font-medium text-accent hover:opacity-80 transition-opacity mt-2"
                >
                  <span class="hs-collapse-open:hidden">Read more</span>
                  <span class="hidden hs-collapse-open:block">Show less</span>
                </button>
              </>
            ) : (
              <>
                {bio.split('\n\n').filter(Boolean).map((para) => (
                  <p class="text-lg text-body-muted">{para}</p>
                ))}
              </>
            )}
          </div>
        )}
      </div>
    </div>
  </section>

  {hasGear && (
    <section data-animate class="animate-reveal py-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="border-t border-border pt-12 sm:pt-16">
          <p class="font-mono text-xs uppercase tracking-wider text-muted">Equipment</p>
          <h2 class="mt-4 font-display text-2xl text-ink" data-config="about.gear.heading">
            {gearLabel}
          </h2>
          <div class="mt-10 flex flex-col rounded-lg border border-border bg-canvas-alt divide-y divide-border">
            {gearList.map((item) => (
              <div class="inline-flex items-center gap-x-3 py-3.5 px-5 text-lg text-ink">
                <svg class="shrink-0 size-4 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                </svg>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <Plugins name="about.after-gear" />

  {cta && (
    <div data-animate class="animate-reveal">
      <CTA
        heading={cta.heading}
        buttonText={cta.link}
        configPrefix="about.call_to_action"
        configButtonKey="link"
      />
    </div>
  )}
</script>
</BaseLayout>
