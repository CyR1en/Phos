---
import BaseLayout from '@layouts/BaseLayout.astro'
import config from '@content/site-config.json'
import CTA from '@components/CTA.astro'

const aboutPhoto = config.about.photo || ''
const aboutPhotoFull = config.about.photoFull || ''
const gear = config.about.gear || {}
const gearLabel = gear.heading || 'My Gear'
const gearList = gear.equipment || []
const hasGear = gearList.length > 0
const bio = config.about.bio || ''
---

<BaseLayout title="About">
  <!-- Photo + Intro -->
  <section data-animate class="animate-reveal mx-auto max-w-7xl px-4 pt-12 sm:pt-16 pb-0 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12 items-center">
      {aboutPhoto && (
        <div class="overflow-hidden rounded-xl bg-muted dark:bg-muted-dark">
          <img
            src={aboutPhoto}
            alt=""
            class="h-full w-full object-cover"
            data-full-src={aboutPhotoFull || undefined}
            loading="eager"
          />
        </div>
      )}
      <div class={aboutPhoto ? '' : 'lg:col-span-2'}>
        <p class="text-sm font-medium uppercase tracking-widest text-subtle dark:text-subtle-dark">About</p>
        <h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
          {config.about.photographer.name}
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-subtle dark:text-subtle-dark">
          {config.about.intro}
        </p>
      </div>
    </div>
  </section>

  <!-- Bio -->
  {bio.trim() && (
    <section data-animate class="animate-reveal mx-auto max-w-3xl px-4 py-12 sm:py-16 sm:px-6 lg:px-8">
      <div class="space-y-5 text-base leading-relaxed text-subtle dark:text-subtle-dark sm:text-lg">
        {bio.split('\n\n').map((para) => (
          <p>{para}</p>
        ))}
      </div>
    </section>
  )}

  <!-- Gear -->
  {hasGear && (
    <section data-animate class="animate-reveal mx-auto max-w-3xl px-4 pb-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-border dark:border-border-dark p-6 sm:p-8">
        <h2 class="text-xl font-semibold text-ink dark:text-ink-dark">
          {gearLabel}
        </h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {gearList.map((item) => (
            <li class="flex items-center gap-3 text-subtle dark:text-subtle-dark">
              <svg class="h-4 w-4 shrink-0 text-ink/40 dark:text-ink-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- CTA -->
  <CTA />
</BaseLayout>

<script>
  window.addEventListener('load', () => {
    const img = document.querySelector('img[data-full-src]')
    if (img && img.dataset.fullSrc) {
      const full = img.dataset.fullSrc
      const fullImg = new Image()
      fullImg.onload = () => { img.src = full; img.removeAttribute('data-full-src') }
      fullImg.src = full
    }
  }, { once: true, passive: true })
</script>
