---
import BaseLayout from '@layouts/BaseLayout.astro'
import config from '@content/site-config.json'
import Plugins from '@components/Plugins.astro'

const aboutPhoto = config.about.photographer?.photo || ''
const gear = config.about.gear || {}
const gearLabel = gear.heading || 'My Gear'
const gearList = gear.equipment || []
const hasGear = gearList.length > 0
const bio = config.about.photographer?.bio || ''
const cta = config.about.call_to_action
const ogTitle = config.about?.og_title || 'About'
const ogDescription = config.about?.og_description
---

<BaseLayout title={ogTitle} description={ogDescription}>
  <section data-animate class="animate-reveal flex h-dvh flex-col lg:flex-row overflow-hidden">
    <div class="relative h-[40vh] lg:h-full w-full lg:w-1/2 shrink-0 overflow-hidden bg-phos-stone">
      {aboutPhoto ? (
        <img
          src={aboutPhoto}
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
          loading="eager"
        />
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-phos-stone to-phos-hairline" />
      )}
    </div>
    <div class="relative flex-1 overflow-y-auto flex items-center px-6 py-8 lg:px-12 lg:py-0 xl:px-16">
      <div class="max-w-xl">
        <p class="phos-mono-label text-phos-coral">About</p>
        <h1 class="mt-6 font-display text-phos-display-product text-phos-ink leading-none" data-config="about.photographer.name">
          {config.about.photographer.name}
        </h1>
        <p class="mt-8 border-l-2 border-phos-coral pl-6 phos-body-lg text-phos-body-muted leading-relaxed" data-config="about.photographer.intro">
          {config.about.photographer.intro}
        </p>
        <div class="mt-10 h-px w-24 bg-phos-hairline" />
        {bio.trim() && (
          <div class="mt-6 line-clamp-3 sm:line-clamp-4 space-y-3">
            {bio.split('\n\n').filter(Boolean).map((para) => (
              <p class="phos-body-lg text-phos-body-muted">{para}</p>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  {hasGear && (
    <section data-animate class="animate-reveal py-phos-section">
      <div class="mx-auto max-w-3xl px-6 sm:px-6 lg:px-8">
        <div class="border-t border-phos-hairline pt-12 sm:pt-16">
          <p class="phos-mono-label text-phos-coral">Equipment</p>
          <h2 class="mt-4 font-display text-phos-heading2 text-phos-ink" data-config="about.gear.heading">
            {gearLabel}
          </h2>
          <ul class="mt-10 space-y-4">
            {gearList.map((item) => (
              <li class="flex items-start gap-3 border-l-2 border-phos-coral pl-4 phos-body-lg text-phos-ink/80">
                <svg class="mt-0.5 size-4 shrink-0 text-phos-coral" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}

  <Plugins name="about.after-gear" />

  {cta && (
    <section data-animate class="animate-reveal pt-phos-section pb-0">
      <div class="mx-auto max-w-3xl px-6 sm:px-6 lg:px-8">
        <div class="rounded-phos-lg bg-phos-deep-green px-8 py-16 text-center sm:px-16 sm:py-20 lg:py-phos-section">
          <p class="phos-mono-label text-phos-coral">Contact</p>
          <h2 class="mt-4 font-display text-phos-display-heading text-phos-canvas" data-config="about.call_to_action.heading">
            {cta.heading}
          </h2>
          <a
            href="/contact"
            class="mt-10 inline-flex items-center rounded-phos-pill bg-phos-canvas px-6 py-3 phos-button text-phos-primary hover:opacity-90 transition-opacity"
          >
            <span data-config="about.call_to_action.link">{cta.link}</span>
            <svg class="ml-2 size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
