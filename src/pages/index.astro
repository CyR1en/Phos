---
import BaseLayout from '@layouts/BaseLayout.astro'
import Hero from '@components/Hero.astro'
import Services from '@components/Services.astro'
import Testimonials from '@components/Testimonials.astro'
import CTA from '@components/CTA.astro'
import CategoryCard from '@components/CategoryCard.astro'
import manifest from '@content/categories.json'
import config from '@content/site-config.json'

const { categories, heroPriority } = manifest
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321'
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: config.about.photographer.name,
  description: config.site.description,
  url: siteUrl,
  image: heroPriority.length > 0 ? `${siteUrl}${heroPriority[0].full}` : undefined,
}

const ogImage = config.site?.og?.image || (heroPriority.length > 0 ? heroPriority[0].full : undefined)
const ogTitle = config.home?.og_title || config.site.title
const ogDescription = config.home?.og_description || config.site.description
---

<BaseLayout title={ogTitle} description={ogDescription} image={ogImage}>
  <Hero heroPriority={heroPriority} />

  {config.home.services.enabled !== false && (
    <div data-animate class="animate-reveal">
      <Services />
    </div>
  )}

  {config.home.portfolio.enabled !== false && (
    <section id="portfolio" data-animate class="animate-reveal py-phos-section">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="flex flex-wrap items-end justify-between gap-6">
          <div>
            <p class="phos-mono-label text-phos-muted dark:text-phos-muted">Portfolio</p>
            <h2 class="mt-4 font-display text-phos-display-heading text-phos-ink dark:text-phos-ink" data-config="home.portfolio.heading">{config.home.portfolio.heading}</h2>
          </div>
          <a href="/portfolio" class="phos-button text-phos-ink dark:text-phos-ink underline underline-offset-4 hover:opacity-80 transition-opacity">View all work</a>
        </div>

        {categories.length > 0 ? (
          <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {categories.slice(0, 6).map((cat) => (
              <CategoryCard
                name={cat.name}
                slug={cat.slug}
                description={cat.description}
                cover={cat.cover}
                coverWidth={cat.coverWidth}
                coverHeight={cat.coverHeight}
                photoCount={cat.photoCount}
                blur={cat.coverBlur}
              />
            ))}
          </div>
        ) : (
          <div class="mt-10 py-24 text-center">
            <p class="phos-body-lg text-phos-muted dark:text-phos-muted">No galleries yet. Add photo folders to <code class="rounded-phos-xs bg-phos-stone dark:bg-phos-stone px-2 py-0.5 phos-caption">photos/</code> and republish.</p>
          </div>
        )}
      </div>
    </section>
  )}

  {config.home.testimonials.enabled !== false && (
    <div data-animate class="animate-reveal">
      <Testimonials />
    </div>
  )}

  {config.home.cta.enabled !== false && (
    <div data-animate class="animate-reveal">
      <CTA />
    </div>
  )}

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
