---
import BaseLayout from '@layouts/BaseLayout.astro'
import config from '@content/site-config.json'

const { heading, subheading, submitBtn } = config.contact.format
const { host, port, user, pass, fromEmail, toEmail } = config.contact.smtp
const hasSmtp = Boolean(host && port && user && pass && fromEmail && toEmail)
const email = config.about.photographer?.email || ''
---

<BaseLayout title={heading}>
  <section data-animate class="animate-reveal mx-auto max-w-2xl px-4 pt-16 pb-16 sm:pt-20 sm:pb-24 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{heading}</h1>
    <p class="mt-4 text-subtle dark:text-subtle-dark">
      {subheading}
    </p>

    {hasSmtp ? (
      <>
        {email && (
          <p class="mt-6 text-sm text-subtle dark:text-subtle-dark">
            Or reach out directly at <a href={`mailto:${email}`} class="font-medium text-ink dark:text-ink-dark underline underline-offset-2 hover:no-underline">{email}</a>
          </p>
        )}

        <form id="contact-form" class="mt-6 sm:mt-8 space-y-5 sm:space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium">Name</label>
            <input
              type="text" id="name" name="name" required
              class="mt-1 block w-full rounded-lg border border-border dark:border-border-dark bg-transparent px-4 py-3 sm:py-2.5 text-sm outline-none focus:ring-2 focus:ring-ink/20 dark:focus:ring-ink-dark/20 transition-shadow"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium">Email</label>
            <input
              type="email" id="email" name="email" required
              class="mt-1 block w-full rounded-lg border border-border dark:border-border-dark bg-transparent px-4 py-3 sm:py-2.5 text-sm outline-none focus:ring-2 focus:ring-ink/20 dark:focus:ring-ink-dark/20 transition-shadow"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium">Message</label>
            <textarea
              id="message" name="message" rows="5" required
              class="mt-1 block w-full rounded-lg border border-border dark:border-border-dark bg-transparent px-4 py-3 sm:py-2.5 text-sm outline-none focus:ring-2 focus:ring-ink/20 dark:focus:ring-ink-dark/20 transition-shadow resize-y"
            ></textarea>
          </div>

          <button type="submit"
            class="w-full sm:w-auto rounded-lg bg-ink dark:bg-ink-dark px-6 py-3 sm:py-2.5 text-sm font-medium text-surface dark:text-surface-dark hover:opacity-90 transition-opacity"
          >{submitBtn}</button>

          <div id="form-status" class="hidden rounded-lg p-4 text-sm"></div>
        </form>

        <script>
          const form = document.getElementById('contact-form')
          const status = document.getElementById('form-status')
          const btn = form.querySelector('button[type="submit"]')
          const originalBtnText = btn.textContent

          form.addEventListener('submit', async (e) => {
            e.preventDefault()
            status.className = 'hidden'
            btn.disabled = true
            btn.textContent = 'Sending...'

            const formData = new FormData(form)

            try {
              const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  name: formData.get('name'),
                  email: formData.get('email'),
                  message: formData.get('message'),
                }),
              })

              const data = await res.json()

              if (!res.ok) {
                throw new Error(data.error || `Submission failed (${res.status})`)
              }

              status.className =
                'rounded-lg p-4 text-sm bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-200'
              status.textContent = "Message sent! I'll get back to you soon."
              form.reset()
            } catch (err) {
              status.className =
                'rounded-lg p-4 text-sm bg-red-50 dark:bg-red-900/20 text-red-800 dark:text-red-200'
              status.textContent = err.message || 'Something went wrong. Please try again.'
            } finally {
              btn.disabled = false
              btn.textContent = originalBtnText
            }
          })
        </script>
      </>
    ) : (
      <div class="mt-8 sm:mt-10 rounded-lg border border-border dark:border-border-dark p-5 sm:p-6 text-center">
        <p class="text-subtle dark:text-subtle-dark">
          Contact form is not configured yet. Configure SMTP settings in the admin dashboard to enable it.
        </p>
        {email && (
          <p class="mt-2 text-sm text-subtle">
            Reach out directly at <a href={`mailto:${email}`} class="font-medium text-ink dark:text-ink-dark underline underline-offset-2 hover:no-underline">{email}</a>
          </p>
        )}
      </div>
    )}
  </section>
</BaseLayout>
