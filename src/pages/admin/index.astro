---
import { Dashboard } from '../../components/admin/Dashboard.tsx'
import '../../styles/global.css'
---

<!DOCTYPE html>
<html lang="en" class="bg-canvas text-ink" data-theme="theme-rose-pine">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Phos</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function() {
        fetch('/site-config.json', { credentials: 'same-origin' })
          .then(function(r) { return r.ok ? r.json() : null })
          .then(function(cfg) {
            if (cfg && cfg.site && cfg.site.theme) {
              document.documentElement.setAttribute('data-theme', cfg.site.theme);
            }
          })
          .catch(function() {});
      })();
    </script>
  </head>
  <body class="font-body antialiased">
    <div id="admin-root">
      <Dashboard client:only="preact" />
    </div>

    <script>
      import 'preline';
    </script>
  </body>
</html>
