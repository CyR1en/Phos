---
import BaseLayout from '@layouts/BaseLayout.astro'
import PhotoCard from '@components/PhotoCard.astro'
import Lightbox from '@components/Lightbox.astro'
import manifest from '@content/categories.json'
import config from '@content/site-config.json'

const { categories } = manifest

interface FlatPhoto {
  filename: string
  title: string
  full: string
  thumb: string
  thumbMobile: string
  width: number | null
  height: number | null
  blur: string
  category: string
  categoryName: string
}

const allPhotos: FlatPhoto[] = categories.flatMap((cat) =>
  cat.photos.map((p) => ({
    ...p,
    category: cat.slug,
    categoryName: cat.name,
  }))
)

const ogTitle = config.portfolio?.og_title || 'Portfolio'
const ogDescription = config.portfolio?.og_description
---

<BaseLayout title={ogTitle} description={ogDescription} page="portfolio">
  <section class="pt-24 pb-12">
    <div class="mx-auto max-w-7xl px-6 sm:px-6 lg:px-8">
      <p class="phos-mono-label text-phos-muted dark:text-phos-muted">Portfolio</p>
      <h1 class="mt-4 font-display text-phos-display-heading text-phos-ink dark:text-phos-ink">All work</h1>
      <p class="mt-4 phos-body-lg text-phos-body-muted dark:text-phos-body-muted">All photos across every category</p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 pb-16 pt-6 sm:pb-24 sm:pt-8 sm:px-6 lg:px-8">
    <div id="filters" class="mb-10 flex flex-wrap gap-2">
      <button class="filter-btn phos-button rounded-phos-pill border border-phos-primary dark:border-phos-primary bg-phos-primary dark:bg-phos-primary px-4 py-2 text-phos-canvas dark:text-phos-canvas min-h-[36px] transition-colors" data-filter="all" aria-pressed="true">
        All
      </button>
      {categories.map((cat) => (
        <button class="filter-btn phos-button rounded-phos-pill border border-phos-border dark:border-phos-border px-4 py-2 phos-button text-phos-ink dark:text-phos-ink hover:border-phos-primary dark:hover:border-phos-primary min-h-[36px] transition-colors" data-filter={cat.slug} aria-pressed="false">
          {cat.name}
        </button>
      ))}
    </div>

    <div id="gallery-grid" class="masonry">
      {allPhotos.map((photo, i) => (
        <div class="gallery-item" data-category={photo.category}>
          <PhotoCard
            filename={photo.filename}
            title={photo.title}
            thumb={photo.thumb}
            thumbMobile={photo.thumbMobile}
            full={photo.full}
            width={photo.width}
            height={photo.height}
            blur={photo.blur}
            index={i}
            category={photo.category}
          />
        </div>
      ))}
    </div>

    <div id="empty-state" class="hidden py-24 text-center phos-body-lg text-phos-muted dark:text-phos-muted">
      No photos match the selected category.
    </div>
  </section>

  <Lightbox photos={allPhotos} />

  <script>
    const filterBtns = document.querySelectorAll('.filter-btn')
    const items = document.querySelectorAll('.gallery-item')
    const emptyState = document.getElementById('empty-state')
    const fullData = JSON.parse(document.getElementById('lightbox-data')?.textContent || '[]')

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter

        filterBtns.forEach((b) => {
          b.classList.remove('bg-phos-primary', 'dark:bg-phos-primary', 'text-phos-canvas', 'dark:text-phos-canvas', 'border-phos-primary', 'dark:border-phos-primary')
          b.classList.add('border-phos-border', 'dark:border-phos-border', 'text-phos-ink', 'dark:text-phos-ink')
          b.setAttribute('aria-pressed', 'false')
        })
        btn.classList.add('bg-phos-primary', 'dark:bg-phos-primary', 'text-phos-canvas', 'dark:text-phos-canvas', 'border-phos-primary', 'dark:border-phos-primary')
        btn.classList.remove('border-phos-border', 'dark:border-phos-border', 'text-phos-ink', 'dark:text-phos-ink')
        btn.setAttribute('aria-pressed', 'true')

        let visible = 0
        let newIdx = 0
        items.forEach((item) => {
          const matches = filter === 'all' || item.dataset.category === filter
          item.style.display = matches ? '' : 'none'
          if (matches) {
            visible++
            const indexBtn = item.querySelector('[data-index]')
            if (indexBtn) indexBtn.dataset.index = newIdx++
          }
        })

        emptyState?.classList.toggle('hidden', visible > 0)

        const filtered = filter === 'all' ? fullData : fullData.filter(p => p.category === filter)
        window.__updateLightboxData(filtered)
      })
    })
  </script>
</BaseLayout>
