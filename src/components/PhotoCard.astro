---
export interface Props {
  filename: string
  title: string
  thumb: string
  thumbMobile: string
  full: string
  width: number | null
  height: number | null
  blur: string
  index: number
  category?: string
}

const { filename, title, thumb, thumbMobile } = Astro.props
---

<img
  class="w-full h-auto object-cover rounded-lg"
  src={thumb}
  srcset={`${thumbMobile} 400w, ${thumb} 800w`}
  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
  alt={title}
  loading="lazy"
  decoding="async"
/>
