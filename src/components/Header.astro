---
import ThemeToggle from './ThemeToggle.astro'
import config from '@content/site-config.json'
import { readFileSync, readdirSync, existsSync } from 'node:fs'
import { extname, join } from 'node:path'

const publicDir = join(process.cwd(), 'public')
const publicFiles = existsSync(publicDir) ? readdirSync(publicDir) : []
const logoFile = publicFiles.find(f => f === 'logo.svg')
const lightLogo = publicFiles.find(f => f.startsWith('logo_light.'))
const darkLogo = publicFiles.find(f => f.startsWith('logo_dark.'))

let logoSvg = null
let logoLight = null
let logoDark = null

if (logoFile) {
  logoSvg = readFileSync(publicDir + '/logo.svg', 'utf-8')
} else if (lightLogo) {
  logoLight = '/' + lightLogo
  const ext = extname(lightLogo)
  const darkName = darkLogo || `logo_dark${ext}`
  logoDark = darkLogo ? '/' + darkLogo : '/' + darkName
}
---

<header class="sticky top-0 z-40 border-b border-phos-hairline dark:border-phos-hairline bg-white/85 dark:bg-neutral-950/85 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-8">
    <a href="/" class="flex items-center gap-3 shrink-0">
      {logoSvg ? (
        <span class="block h-8 w-auto text-phos-primary dark:text-phos-primary" set:html={logoSvg} />
      ) : logoLight ? (
        <>
          <img src={logoLight} alt={config.site.title} class="block h-8 w-auto dark:hidden" />
          <img src={logoDark} alt={config.site.title} class="hidden h-8 w-auto dark:block" />
        </>
      ) : null}
      <span class="font-display text-xl text-phos-primary dark:text-phos-primary">{config.site.title}</span>
    </a>

    <div class="hidden items-center gap-8 sm:flex">
      <a href="/" class="phos-button text-phos-ink dark:text-phos-ink hover:text-phos-primary dark:hover:text-phos-primary transition-colors">Home</a>
      <a href="/portfolio" class="phos-button text-phos-ink dark:text-phos-ink hover:text-phos-primary dark:hover:text-phos-primary transition-colors">Portfolio</a>
      <a href="/about" class="phos-button text-phos-ink dark:text-phos-ink hover:text-phos-primary dark:hover:text-phos-primary transition-colors">About</a>
      <a href="/contact" class="phos-button text-phos-ink dark:text-phos-ink hover:text-phos-primary dark:hover:text-phos-primary transition-colors">Contact</a>
    </div>

    <div class="flex items-center gap-3">
      <a href="/contact" class="hidden sm:inline-flex phos-button items-center rounded-phos-pill bg-phos-primary dark:bg-phos-primary px-5 py-2 text-phos-canvas dark:text-phos-canvas hover:opacity-90 transition-opacity">Get in touch</a>
      <ThemeToggle />
      <button id="menu-btn" class="flex h-9 w-9 items-center justify-center rounded-phos-sm text-phos-ink dark:text-phos-ink hover:bg-phos-stone dark:hover:bg-phos-stone transition-colors sm:hidden" aria-label="Open menu">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile nav overlay -->
<div id="mobile-nav" class="fixed inset-0 z-50 hidden sm:hidden" role="dialog" aria-modal="true" aria-label="Navigation">
  <div id="nav-backdrop" class="absolute inset-0 bg-black/60 dark:bg-neutral-950/80 backdrop-blur-sm"></div>
  <div id="nav-drawer" class="absolute right-0 top-0 h-full w-full max-w-sm bg-phos-canvas dark:bg-phos-canvas">
    <div class="flex items-center justify-between border-b border-phos-hairline dark:border-phos-hairline px-6 py-5">
      <div class="flex items-center gap-3">
        {logoSvg ? (
          <span class="block h-8 w-auto text-phos-primary dark:text-phos-primary" set:html={logoSvg} />
        ) : logoLight ? (
          <>
            <img src={logoLight} alt={config.site.title} class="block h-8 w-auto dark:hidden" />
            <img src={logoDark} alt={config.site.title} class="hidden h-8 w-auto dark:block" />
          </>
        ) : null}
        <span class="font-display text-xl text-phos-primary dark:text-phos-primary">{config.site.title}</span>
      </div>
      <button id="menu-close" class="flex h-9 w-9 items-center justify-center rounded-phos-sm text-phos-ink dark:text-phos-ink hover:bg-phos-stone dark:hover:bg-phos-stone transition-colors" aria-label="Close menu">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>
    </div>
    <nav class="flex flex-col gap-2 px-6 pt-8">
      <a href="/" class="rounded-phos-sm px-4 py-3 phos-button text-phos-ink dark:text-phos-ink hover:bg-phos-stone dark:hover:bg-phos-stone transition-colors">Home</a>
      <a href="/portfolio" class="rounded-phos-sm px-4 py-3 phos-button text-phos-ink dark:text-phos-ink hover:bg-phos-stone dark:hover:bg-phos-stone transition-colors">Portfolio</a>
      <a href="/about" class="rounded-phos-sm px-4 py-3 phos-button text-phos-ink dark:text-phos-ink hover:bg-phos-stone dark:hover:bg-phos-stone transition-colors">About</a>
      <a href="/contact" class="rounded-phos-sm px-4 py-3 phos-button text-phos-ink dark:text-phos-ink hover:bg-phos-stone dark:hover:bg-phos-stone transition-colors">Contact</a>
    </nav>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('menu-btn')
  const menuClose = document.getElementById('menu-close')
  const mobileNav = document.getElementById('mobile-nav')
  const navDrawer = document.getElementById('nav-drawer')
  const navBackdrop = document.getElementById('nav-backdrop')

  function openMenu() {
    mobileNav.classList.remove('hidden')
    mobileNav.classList.add('flex')
    document.body.classList.add('mobile-nav-open')
    window.__lenis?.stop()
    navBackdrop.classList.add('nav-backdrop-enter')
    navDrawer.classList.add('nav-enter')
    menuClose?.focus()
  }

  function closeMenu() {
    navBackdrop.classList.remove('nav-backdrop-enter')
    navBackdrop.classList.add('nav-backdrop-exit')
    navDrawer.classList.remove('nav-enter')
    navDrawer.classList.add('nav-exit')
    menuBtn?.focus()
    setTimeout(() => {
      mobileNav.classList.add('hidden')
      mobileNav.classList.remove('flex')
      navBackdrop.classList.remove('nav-backdrop-exit')
      navDrawer.classList.remove('nav-exit')
      document.body.classList.remove('mobile-nav-open')
      window.__lenis?.start()
    }, 250)
  }

  menuBtn?.addEventListener('click', openMenu)
  menuClose?.addEventListener('click', closeMenu)
  navBackdrop?.addEventListener('click', closeMenu)

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileNav.classList.contains('hidden')) {
      closeMenu()
    }
  })

  document.addEventListener('astro:before-swap', closeMenu)
</script>
