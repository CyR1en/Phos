---
import ThemeToggle from './ThemeToggle.astro'
import config from '@content/site-config.json'
import { readFileSync, readdirSync, existsSync } from 'node:fs'
import { extname, join } from 'node:path'

const publicDir = join(process.cwd(), 'public')
const publicFiles = existsSync(publicDir) ? readdirSync(publicDir) : []
const logoFile = publicFiles.find(f => f === 'logo.svg')
const lightLogo = publicFiles.find(f => f.startsWith('logo_light.'))
const darkLogo = publicFiles.find(f => f.startsWith('logo_dark.'))

let logoSvg = null
let logoLight = null
let logoDark = null

if (logoFile) {
  logoSvg = readFileSync(publicDir + '/logo.svg', 'utf-8')
} else if (lightLogo) {
  logoLight = '/' + lightLogo
  const ext = extname(lightLogo)
  const darkName = darkLogo || `logo_dark${ext}`
  logoDark = darkLogo ? '/' + darkLogo : '/' + darkName
}
---

<header class="sticky top-0 z-40 border-b border-border bg-canvas/85 backdrop-blur-md dark:bg-canvas/85">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-8">
    <a href="/" class="flex items-center gap-1.5 shrink-0">
      <div>
        {logoSvg ? (
          <span class="size-6 text-ink" set:html={logoSvg} />
        ) : logoLight ? (
          <>
            <img src={logoLight} alt={config.site.title} class="h-6 w-auto dark:hidden" />
            <img src={logoDark} alt={config.site.title} class="hidden h-6 w-auto dark:block" />
          </>
        ) : null}
      </div>
      <div class="font-display text-xl tracking-wide text-ink">{config.site.title}</div>
    </a>

    <div class="hidden items-center gap-8 sm:flex">
      <a href="/" class="text-sm font-medium text-ink hover:text-primary transition-colors">Home</a>
      <a href="/portfolio" class="text-sm font-medium text-ink hover:text-primary transition-colors">Portfolio</a>
      <a href="/about" class="text-sm font-medium text-ink hover:text-primary transition-colors">About</a>
      <a href="/contact" class="text-sm font-medium text-ink hover:text-primary transition-colors">Contact</a>
    </div>

    <div class="flex items-center gap-3">
      <a href="/contact" class="hidden sm:inline-flex items-center rounded-pill bg-primary px-5 py-2 text-sm font-medium text-primary-text hover:bg-primary-hover transition-colors">Get in touch</a>
      <ThemeToggle />
      <button id="menu-btn" type="button" class="flex h-11 w-11 items-center justify-center rounded-sm text-ink hover:bg-surface transition-colors sm:hidden" data-hs-overlay="#mobile-nav" aria-label="Open menu">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<div id="mobile-nav" class="hs-overlay hs-overlay-open:translate-x-0 hidden fixed inset-y-0 end-0 z-[80] w-full max-w-sm bg-canvas border-s border-border transition-transform translate-x-full" role="dialog" tabindex="-1" aria-label="Navigation">
  <div class="flex items-center justify-between border-b border-border px-6 py-5">
    <div class="flex items-center gap-1.5">
      <div>
        {logoSvg ? (
          <span class="size-6 text-ink" set:html={logoSvg} />
        ) : logoLight ? (
          <>
            <img src={logoLight} alt={config.site.title} class="h-6 w-auto dark:hidden" />
            <img src={logoDark} alt={config.site.title} class="hidden h-6 w-auto dark:block" />
          </>
        ) : null}
      </div>
      <div class="font-display text-xl tracking-wide text-ink">{config.site.title}</div>
      <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>
  </div>
  <nav class="flex flex-col gap-2 px-6 pt-8">
    <a href="/" class="rounded-sm px-4 py-3 text-sm font-medium text-ink hover:bg-surface transition-colors">Home</a>
    <a href="/portfolio" class="rounded-sm px-4 py-3 text-sm font-medium text-ink hover:bg-surface transition-colors">Portfolio</a>
    <a href="/about" class="rounded-sm px-4 py-3 text-sm font-medium text-ink hover:bg-surface transition-colors">About</a>
    <a href="/contact" class="rounded-sm px-4 py-3 text-sm font-medium text-ink hover:bg-surface transition-colors">Contact</a>
  </nav>
</div>

<script>
  const mobileNav = document.getElementById('mobile-nav')

  function onOpen() {
    document.body.classList.add('mobile-nav-open')
    window.__lenis?.stop()
  }

  function onClose() {
    document.body.classList.remove('mobile-nav-open')
    window.__lenis?.start()
  }

  mobileNav?.addEventListener('open.hs.overlay', onOpen)
  mobileNav?.addEventListener('close.hs.overlay', onClose)

  document.addEventListener('astro:before-swap', () => {
    const HSOverlay = (window as any).HSOverlay
    if (HSOverlay) {
      const instance = HSOverlay.getInstance('#mobile-nav')
      if (instance?.isOpened()) instance.close()
    }
    onClose()
  })
</script>
