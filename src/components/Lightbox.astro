---
export interface Photo {
  filename: string
  title: string
  full: string
  thumb: string
  width: number | null
  height: number | null
  blur: string
  category?: string
}

export interface Props {
  photos: Photo[]
}

const { photos } = Astro.props
const serialized = JSON.stringify(photos)
---

<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Image lightbox"
>
  <button id="lightbox-close" class="absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-phos-pill bg-white/10 text-white hover:bg-white/20 transition-colors" aria-label="Close lightbox">
    <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
  </button>

  <button id="lightbox-prev" class="absolute left-2 top-1/2 z-10 hidden -translate-y-1/2 items-center justify-center rounded-phos-pill bg-white/10 p-3 text-white hover:bg-white/20 transition-colors sm:flex" aria-label="Previous image">
    <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
  </button>

  <button id="lightbox-next" class="absolute right-2 top-1/2 z-10 hidden -translate-y-1/2 items-center justify-center rounded-phos-pill bg-white/10 p-3 text-white hover:bg-white/20 transition-colors sm:flex" aria-label="Next image">
    <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
  </button>

  <div class="flex h-full w-full items-center justify-center p-2 sm:p-12">
    <div class="relative max-h-[90vh] max-w-full">
      <div id="lightbox-blur" class="absolute inset-0 rounded-phos-xs bg-cover bg-center blur-xl" style="display:none"></div>
      <img id="lightbox-img" class="relative max-h-[90vh] max-w-full w-auto h-auto object-contain select-none rounded-phos-xs" src="" alt="" style="transition: opacity 0.3s ease" />
      <div id="lightbox-error" class="absolute inset-0 hidden flex-col items-center justify-center rounded-phos-xs bg-black/60 text-white/60 phos-caption">
        <span>Failed to load image</span>
      </div>
      <!-- Swipe hint for mobile -->
      <div id="swipe-hint" class="absolute inset-x-0 top-1/2 -translate-y-1/2 flex justify-between pointer-events-none opacity-0 transition-opacity duration-1000 sm:hidden">
        <svg class="size-8 text-white/30 -translate-x-1" viewBox="0 0 24 24" fill="currentColor"><path d="M15 18l-6-6 6-6"/></svg>
        <svg class="size-8 text-white/30 translate-x-1" viewBox="0 0 24 24" fill="currentColor"><path d="M9 18l6-6-6-6"/></svg>
      </div>
    </div>
  </div>

  <div id="lightbox-title" class="absolute bottom-4 left-1/2 -translate-x-1/2 phos-caption text-white/70 text-center px-4 max-w-md pointer-events-none"></div>
  <div id="lightbox-counter" class="absolute bottom-12 left-1/2 -translate-x-1/2 phos-micro text-white/40 pointer-events-none"></div>
  <div id="lightbox-data" style="display:none" set:text={serialized} />
</div>

<script>
  const lightbox = document.getElementById('lightbox')
  const img = document.getElementById('lightbox-img')
  const blurEl = document.getElementById('lightbox-blur')
  const errorEl = document.getElementById('lightbox-error')
  const titleEl = document.getElementById('lightbox-title')
  const counterEl = document.getElementById('lightbox-counter')
  const closeBtn = document.getElementById('lightbox-close')
  const prevBtn = document.getElementById('lightbox-prev')
  const nextBtn = document.getElementById('lightbox-next')
  const swipeHint = document.getElementById('swipe-hint')

  let currentIndex = 0
  let transitioning = false
  let lastFocused = null

  function getPhotos() {
    try {
      const el = document.getElementById('lightbox-data')
      return JSON.parse(el.textContent)
    } catch { return [] }
  }

  function open(idx) {
    const data = getPhotos()
    const photo = data[idx]
    if (!photo) return
    currentIndex = idx
    transitioning = false
    img.src = photo.full
    img.alt = photo.title
    errorEl.classList.add('hidden')
    showBlur(photo)
    updateMeta(photo, data)

    img.onload = () => { img.style.opacity = '1'; hideBlur(); preloadAdjacent(data) }
    img.onerror = () => { img.style.opacity = '1'; showError(); hideBlur() }

    if (img.complete && img.naturalWidth) { img.style.opacity = '1'; hideBlur(); preloadAdjacent(data) }

    lightbox.classList.remove('hidden')
    lastFocused = document.activeElement
    requestAnimationFrame(() => {
      lightbox.classList.add('flex')
    closeBtn.focus()
    requestAnimationFrame(() => lightbox.classList.add('lightbox-enter'))

    if (swipeHint) {
      swipeHint.style.opacity = '1'
      setTimeout(() => { swipeHint.style.opacity = '0' }, 2000)
    }
    })
    document.body.style.overflow = 'hidden'
  }

  function close() {
    img.style.opacity = '0'
    lightbox.classList.remove('lightbox-enter')
    lightbox.classList.add('lightbox-exit')
    if (lastFocused) { lastFocused.focus(); lastFocused = null }
    setTimeout(() => {
      if (!lightbox.classList.contains('hidden')) {
        lightbox.classList.add('hidden')
        lightbox.classList.remove('flex', 'lightbox-exit')
        document.body.style.removeProperty('overflow')
      }
    }, 200)
  }

  function showBlur(photo) {
    if (photo.blur) {
      blurEl.style.display = 'block'
      blurEl.style.backgroundImage = `url('${photo.blur}')`
    }
  }

  function hideBlur() { blurEl.style.display = 'none' }

  function showError() { errorEl.classList.remove('hidden') }

  function updateMeta(photo, data) {
    titleEl.textContent = photo.title
    counterEl.textContent = `${currentIndex + 1} / ${data.length}`
    prevBtn.classList.toggle('hidden', currentIndex === 0)
    nextBtn.classList.toggle('hidden', currentIndex === data.length - 1)
  }

  function transitionTo(photo, data) {
    if (transitioning || !photo) return
    transitioning = true
    img.style.opacity = '0'
    errorEl.classList.add('hidden')
    showBlur(photo)
    updateMeta(photo, data)

    function onFadeOut(e) {
      if (e && e.propertyName !== 'opacity') return
      img.removeEventListener('transitionend', onFadeOut)
      swapImage(photo, data)
    }

    const dur = parseFloat(getComputedStyle(img).transitionDuration) * 1000 || 300
    if (dur < 10 || img.style.opacity === '0') {
      swapImage(photo, data)
    } else {
      img.addEventListener('transitionend', onFadeOut)
    }
  }

  function swapImage(photo, data) {
    img.src = photo.full
    img.alt = photo.title
    img.onload = () => { hideBlur(); img.style.opacity = '1'; transitioning = false; preloadAdjacent(data) }
    img.onerror = () => { showError(); hideBlur(); img.style.opacity = '1'; transitioning = false }
    if (img.complete && img.naturalWidth) {
      hideBlur(); img.style.opacity = '1'; transitioning = false; preloadAdjacent(data)
    }
  }

  function preloadAdjacent(data) {
    document.querySelectorAll('link[rel="preload"][as="image"][data-lb]').forEach(el => el.remove())
    for (const i of [currentIndex - 1, currentIndex + 1]) {
      if (i >= 0 && i < data.length) {
        const link = document.createElement('link')
        link.rel = 'preload'; link.as = 'image'
        link.href = data[i].full
        link.setAttribute('data-lb', '')
        document.head.appendChild(link)
      }
    }
  }

  function cancelPreload() {
    document.querySelectorAll('link[rel="preload"][as="image"][data-lb]').forEach(el => el.remove())
  }

  function prev() {
    const data = getPhotos()
    if (currentIndex > 0) { currentIndex--; transitionTo(data[currentIndex], data) }
  }

  function next() {
    const data = getPhotos()
    if (currentIndex < data.length - 1) { currentIndex++; transitionTo(data[currentIndex], data) }
  }

  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-index]')
    if (!btn) return
    const idx = parseInt(btn.dataset.index, 10)
    const data = getPhotos()
    if (!isNaN(idx) && idx >= 0 && idx < data.length) open(idx)
  })

  closeBtn.addEventListener('click', close)
  prevBtn.addEventListener('click', prev)
  nextBtn.addEventListener('click', next)

  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return
    if (e.key === 'Escape') { e.preventDefault(); close() }
    if (e.key === 'ArrowLeft') { e.preventDefault(); prev() }
    if (e.key === 'ArrowRight') { e.preventDefault(); next() }
  })

  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close() })

  let tx = 0, ty = 0
  lightbox.addEventListener('touchstart', (e) => { tx = e.changedTouches[0].screenX; ty = e.changedTouches[0].screenY })
  lightbox.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].screenX - tx
    const dy = e.changedTouches[0].screenY - ty
    if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) dx > 0 ? prev() : next()
  })

  window.__updateLightboxData = (data) => {
    const el = document.getElementById('lightbox-data')
    if (el) el.textContent = JSON.stringify(data)
    currentIndex = 0
    if (!lightbox.classList.contains('hidden') && data.length > 0) {
      const photo = data[0]
      img.style.opacity = '0'
      img.src = photo.full
      img.alt = photo.title
      errorEl.classList.add('hidden')
      showBlur(photo)
      updateMeta(photo, data)
      cancelPreload()
      img.onload = () => { img.style.opacity = '1'; hideBlur(); preloadAdjacent(data) }
      img.onerror = () => { img.style.opacity = '1'; showError(); hideBlur() }
      if (img.complete && img.naturalWidth) { img.style.opacity = '1'; hideBlur(); preloadAdjacent(data) }
    }
  }
</script>
