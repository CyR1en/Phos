---
import PhotoGrid from '@components/PhotoGrid.astro'

export interface Photo {
  filename: string
  title: string
  full: string
  thumb: string
  thumbMobile: string
  width: number | null
  height: number | null
  blur: string
  category?: string
}

export interface Props {
  photos: Photo[]
}

const { photos } = Astro.props
---

<PhotoGrid photos={photos} />
