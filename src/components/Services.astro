---
import manifest from '@content/categories.json'
import config from '@content/site-config.json'
const { categories } = manifest
---

<section data-animate class="animate-reveal mx-auto max-w-7xl px-4 py-6 sm:py-12 sm:px-6 lg:px-8">
  <div class="text-center">
    <p class="text-sm font-medium uppercase tracking-widest text-subtle">Services</p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">{config.home.services.heading}</h2>
    <p class="mx-auto mt-4 max-w-2xl text-subtle">{config.home.services.subheading}</p>
  </div>

  <div class="mt-8 sm:mt-12 grid gap-4 sm:gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {
      categories.map((cat) => (
        <a
          href={`/photos/${cat.slug}/`}
          class="group rounded-xl border border-border dark:border-border-dark p-5 sm:p-6 transition-all hover:border-ink/20 dark:hover:border-ink-dark/20 hover:-translate-y-1"
        >
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-muted dark:bg-muted-dark group-hover:bg-ink dark:group-hover:bg-ink-dark transition-colors">
            <svg class="h-6 w-6 text-ink dark:text-ink-dark group-hover:text-surface dark:group-hover:text-surface-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/>
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold">{cat.name}</h3>
          <p class="mt-2 text-sm text-subtle leading-relaxed">
            {cat.description || `${cat.photoCount} photos in gallery`}
          </p>
          <p class="mt-3 text-xs text-subtle dark:text-subtle-dark">{cat.photoCount} photo{cat.photoCount !== 1 ? 's' : ''}</p>
        </a>
      ))
    }
  </div>
</section>
