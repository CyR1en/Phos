---
import manifest from '@content/categories.json'
import config from '@content/site-config.json'
const { categories } = manifest
---

<section data-animate class="animate-reveal mx-auto max-w-7xl px-6 py-16 sm:py-24 lg:py-20 sm:px-6 lg:px-8">
  <div class="border-t border-border pt-12 sm:pt-16">
    <div class="grid gap-8 lg:grid-cols-3 lg:gap-12">
      <div>
        <p class="font-mono text-xs uppercase tracking-wider text-muted">Services</p>
        <h2 class="mt-4 font-display text-xl text-ink" data-config="home.services.heading">{config.home.services.heading}</h2>
      </div>
      <div class="lg:col-span-2">
        <p class="text-lg text-body-muted leading-relaxed" data-config="home.services.subheading">{config.home.services.subheading}</p>
        <div class="mt-10 grid gap-px bg-border sm:grid-cols-2 lg:grid-cols-3">
          {
            categories.filter((cat) => cat.offer_service).map((cat) => (
              <a
                href={`/photo/all/?cat=${cat.slug}`}
                class="group flex flex-col gap-4 bg-canvas p-6 sm:p-8 transition-colors hover:bg-surface-hover"
              >
                <div class="flex h-10 w-10 items-center justify-center">
                  <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
                    <path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/>
                  </svg>
                </div>
                <h3 class="font-display text-xl text-ink">{cat.name}</h3>
                <p class="text-sm text-body-muted leading-relaxed">
                  {cat.description || `${cat.photoCount} photos in gallery`}
                </p>
                <div class="mt-auto flex items-center gap-2 text-sm font-medium text-ink group-hover:gap-3 transition-all">
                  Explore
                  <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
