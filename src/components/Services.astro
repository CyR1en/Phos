---
import manifest from '@content/categories.json'
import config from '@content/site-config.json'
const { categories } = manifest
const serviceCategories = categories.filter((cat) => cat.offer_service)
---

<section data-animate class="animate-reveal mx-auto max-w-7xl px-6 py-20 sm:px-6 lg:px-8">
  <div class="max-w-3xl">
    <p class="font-mono text-xs uppercase tracking-wider text-muted">Services</p>
    <h2 class="mt-4 font-display text-3xl sm:text-4xl text-ink" data-config="home.services.heading">{config.home.services.heading}</h2>
    {config.home.services.subheading && (
      <p class="mt-4 text-lg text-body-muted leading-relaxed max-w-2xl" data-config="home.services.subheading">{config.home.services.subheading}</p>
    )}
  </div>

  <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {serviceCategories.map((cat, i) => (
      <a
        href={`/photo/all/?cat=${cat.slug}`}
        class="group flex flex-col bg-surface border border-border-light rounded-sm p-6 sm:p-8 hover:border-border-hover transition-colors fade-in"
        aria-label={`${cat.name} — ${cat.photoCount} photo${cat.photoCount !== 1 ? 's' : ''}`}
      >
        <span class="font-mono text-[11px] tracking-widest text-accent">
          {(i + 1).toString().padStart(2, '0')}
        </span>

        <h3 class="mt-5 font-display text-xl font-medium text-ink">{cat.name}</h3>

        <p class="mt-1.5 text-sm text-muted">{cat.photoCount} photo{cat.photoCount !== 1 ? 's' : ''}</p>

        {cat.description && (
          <p class="mt-3 text-sm text-body-muted leading-relaxed">{cat.description}</p>
        )}

        <div class="mt-6 flex items-center gap-2 text-sm font-medium text-ink group-hover:gap-3 transition-all">
          Explore
          <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>
    ))
    }
  </div>
</section>
