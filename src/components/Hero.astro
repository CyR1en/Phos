---
export interface Props {
  heroPriority: Array<{
    full: string
    thumb: string
    title: string
    description: string
    blur: string
    width: number | null
    height: number | null
    category: string
    categoryName: string
    hero_priority: number
  }>
}

import config from '@content/site-config.json'

const { heroPriority } = Astro.props
const hasSlideshow = heroPriority.length > 1
const first = heroPriority[0]
---

{first?.thumb && <link rel="preload" href={first.thumb} as="image" fetchpriority="high" />}
<section class="relative flex min-h-[88vh] items-center justify-center overflow-hidden">
  {heroPriority.length > 0 ? (
    <div class="absolute inset-0 hero-parallax" id="hero-bg">
      {heroPriority.map((photo, i) => (
        <div
          class="absolute inset-0 bg-cover bg-center"
          id={i === 0 ? 'hero-active-slide' : undefined}
          style={`background-image: url('${photo.blur}'); opacity: ${i === 0 ? 1 : 0};${hasSlideshow ? ' transition: opacity 1.5s ease;' : ''}`}
          data-hero-slide={i}
          role="img"
          aria-label={photo.title}
        >
          <img
            src={photo.thumb}
            data-full-src={photo.full}
            alt={photo.title}
            class="absolute inset-0 h-full w-full object-cover"
            fetchpriority={i === 0 ? 'high' : 'low'}
          />
        </div>
      ))}
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.45) 35%, rgba(0,0,0,0.15) 70%, rgba(0,0,0,0) 100%);" />
    </div>
  ) : (
    <div class="absolute inset-0 bg-phos-canvas dark:bg-phos-canvas" />
  )}

  <div class="relative z-10 mx-auto w-full max-w-7xl px-6 sm:px-6 lg:px-8">
    <div class="max-w-4xl">
      <p class="phos-mono-label text-white/70" data-config="about.photographer.name">{config.about.photographer.name}</p>
      <h1 class="mt-6 font-display text-white text-phos-heading sm:text-phos-product drop-shadow-sm" data-config="home.hero.heading">
        {config.home.hero.heading}
      </h1>
      <p class="mt-6 max-w-2xl phos-body-lg text-white/80" data-config="home.hero.subheading">
        {config.home.hero.subheading}
      </p>
      <div class="mt-10 flex flex-col items-start gap-3 sm:flex-row">
        <a
          href="/portfolio"
          class="inline-flex items-center rounded-phos-pill bg-white px-6 py-3 phos-button text-zinc-900 hover:bg-zinc-100 transition-colors"
        >
          <span data-config="home.hero.cta1">{config.home.hero.cta1}</span>
          <svg class="ml-2 size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center rounded-phos-pill border border-white/30 px-6 py-3 phos-button text-white hover:bg-white/10 transition-colors"
        >
          <span data-config="home.hero.cta2">{config.home.hero.cta2}</span>
        </a>
      </div>
    </div>
  </div>

  {heroPriority.length > 0 && (
    <div class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2 flex gap-2">
      {heroPriority.map((_, i) => (
        <button
          class="h-1.5 rounded-phos-pill transition-all duration-500"
          class:list={[
            i === 0 ? 'w-8 bg-white' : 'w-1.5 bg-white/40 hover:bg-white/60',
          ]}
          data-hero-dot={i}
          aria-label={`Slide ${i + 1}`}
        />
      ))}
    </div>
  )}
</section>

<script>
  const slides = document.querySelectorAll('[data-hero-slide]')
  const dots = document.querySelectorAll('[data-hero-dot]')
  const heroBg = document.getElementById('hero-bg')
  if (slides.length > 0) {
    window.addEventListener('load', () => {
      slides.forEach((slide) => {
        const img = slide.querySelector('img[data-full-src]')
        if (!img) return
        const fullSrc = img.dataset.fullSrc
        const fullImg = new Image()
        fullImg.onload = () => { img.src = fullSrc; img.removeAttribute('data-full-src') }
        fullImg.src = fullSrc
      })
    }, { once: true, passive: true })
  }

  if (slides.length > 1) {
    let current = 0
    let interval = null

    function showSlide(index) {
      slides.forEach((s, i) => {
        s.style.opacity = i === index ? '1' : '0'
      })
      dots.forEach((d, i) => {
        if (i === index) {
          d.classList.add('w-8', 'bg-white')
          d.classList.remove('w-1.5', 'bg-white/40', 'hover:bg-white/60')
        } else {
          d.classList.remove('w-8', 'bg-white')
          d.classList.add('w-1.5', 'bg-white/40', 'hover:bg-white/60')
        }
      })
      current = index
    }

    function next() {
      showSlide((current + 1) % slides.length)
    }

    function start() {
      if (interval) clearInterval(interval)
      const heroInterval = parseInt(import.meta.env.PUBLIC_HERO_INTERVAL, 10) || 6000
      interval = setInterval(next, heroInterval)
    }

    function stop() {
      if (interval) {
        clearInterval(interval)
        interval = null
      }
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = parseInt(dot.dataset.heroDot, 10)
        if (!isNaN(idx) && idx !== current) showSlide(idx)
        start()
      })
    })

    if (heroBg) {
      heroBg.addEventListener('mouseenter', stop)
      heroBg.addEventListener('mouseleave', start)
    }

    start()


  }

  if (heroBg) {
    let ticking = false
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const y = window.scrollY * 0.4
          heroBg.style.transform = `translate3d(0, ${y}px, 0)`
          ticking = false
        })
        ticking = true
      }
    }, { passive: true })
  }
</script>
