---
export interface Props {
  heroPriority: Array<{
    full: string
    thumb: string
    title: string
    description: string
    blur: string
    width: number | null
    height: number | null
    category: string
    categoryName: string
    hero_priority: number
  }>
}

import config from '@content/site-config.json'

const { heroPriority } = Astro.props
const hasSlideshow = heroPriority.length > 1
const first = heroPriority[0]
const slideshowInterval = config.home.hero.slideshow_interval ?? 6000
const overlayOpacity = config.home.hero.overlay_opacity ?? 0.75
---

{first?.thumb && <link rel="preload" href={first.thumb} as="image" fetchpriority="high" />}
<section class="relative flex min-h-[88vh] items-end justify-center overflow-hidden" data-hero-interval={slideshowInterval}>
  {heroPriority.length > 0 ? (
    <div class="absolute inset-0 z-0 hero-parallax pointer-events-none" id="hero-bg">
      {heroPriority.map((photo, i) => (
        <div
          class="absolute inset-0 bg-cover bg-center"
          id={i === 0 ? 'hero-active-slide' : undefined}
          style={`background-image: url('${photo.blur}'); opacity: ${i === 0 ? 1 : 0};${hasSlideshow ? ' transition: opacity 1.5s ease;' : ''}`}
          data-hero-slide={i}
          role="img"
          aria-label={photo.title}
        >
          <img
            src={photo.thumb}
            data-full-src={photo.full}
            alt={photo.title}
            class="absolute inset-0 h-full w-full object-cover"
            fetchpriority={i === 0 ? 'high' : 'low'}
          />
        </div>
      ))}
      <div class="absolute inset-0" style={`background: linear-gradient(to top, rgba(0,0,0,${overlayOpacity}) 0%, rgba(0,0,0,${overlayOpacity * 0.6}) 20%, rgba(0,0,0,${overlayOpacity * 0.1}) 38%, rgba(0,0,0,0) 45%);`} />
    </div>
  ) : (
    <div class="absolute inset-0 bg-canvas" />
  )}

  <div class="relative z-10 mx-auto w-full max-w-7xl px-6 pb-16 sm:px-6 lg:px-8 lg:pb-20">
    <div class="max-w-4xl">
      <p class="font-mono text-[13px] font-medium uppercase tracking-wider text-[var(--color-phos-dark-text)]/85" data-config="about.photographer.name">{config.about.photographer.name}</p>
      <h1 class="mt-4 font-display text-[var(--color-phos-dark-text)] drop-shadow-sm" style="font-size: clamp(36px, 5vw, 64px); line-height: 1.1;" data-config="home.hero.heading">
        {config.home.hero.heading}
      </h1>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-start">
        <a
          href="/portfolio"
          class="inline-flex items-center justify-center rounded-pill bg-canvas px-5 py-2.5 text-sm font-medium text-ink hover:bg-canvas-alt transition-colors w-full sm:w-auto"
        >
          <span data-config="home.hero.cta1">{config.home.hero.cta1}</span>
          <svg class="ml-2 size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-pill border border-[var(--color-phos-dark-text)]/30 px-5 py-2.5 text-sm font-medium text-[var(--color-phos-dark-text)] hover:bg-[var(--color-phos-dark-text)]/10 transition-colors w-full sm:w-auto"
        >
          <span data-config="home.hero.cta2">{config.home.hero.cta2}</span>
        </a>
      </div>
    </div>
  </div>

  {heroPriority.length > 0 && (
    <div class="absolute bottom-8 left-1/2 z-20 -translate-x-1/2 flex gap-2 pointer-events-auto">
      {heroPriority.map((_, i) => (
        <button
          class="h-1.5 rounded-pill transition-all duration-500"
          class:list={[
            i === 0 ? 'w-8 bg-[var(--color-phos-dark-text)]' : 'w-1.5 bg-[var(--color-phos-dark-text)]/40 hover:bg-[var(--color-phos-dark-text)]/60',
          ]}
          data-hero-dot={i}
          aria-label={`Slide ${i + 1}`}
        />
      ))}
    </div>
  )}
</section>

<script>
  const slides = document.querySelectorAll('[data-hero-slide]')
  const dots = document.querySelectorAll('[data-hero-dot]')
  const heroBg = document.getElementById('hero-bg')
  const heroSection = document.querySelector('[data-hero-interval]')
  if (slides.length > 0) {
    window.addEventListener('load', () => {
      slides.forEach((slide) => {
        const img = slide.querySelector('img[data-full-src]')
        if (!img) return
        const fullSrc = img.dataset.fullSrc
        const fullImg = new Image()
        fullImg.onload = () => { img.src = fullSrc; img.removeAttribute('data-full-src') }
        fullImg.src = fullSrc
      })
    }, { once: true, passive: true })
  }

  if (slides.length > 1) {
    let current = 0
    let interval = null

    function showSlide(index) {
      slides.forEach((s, i) => {
        s.style.opacity = i === index ? '1' : '0'
      })
      dots.forEach((d, i) => {
        if (i === index) {
          d.classList.add('w-8', 'bg-[var(--color-phos-dark-text)]')
          d.classList.remove('w-1.5', 'bg-[var(--color-phos-dark-text)]/40', 'hover:bg-[var(--color-phos-dark-text)]/60')
        } else {
          d.classList.remove('w-8', 'bg-[var(--color-phos-dark-text)]')
          d.classList.add('w-1.5', 'bg-[var(--color-phos-dark-text)]/40', 'hover:bg-[var(--color-phos-dark-text)]/60')
        }
      })
      current = index
    }

    function next() {
      showSlide((current + 1) % slides.length)
    }

    function start() {
      if (interval) clearInterval(interval)
      const heroInterval = parseInt(heroSection.dataset.heroInterval, 10) || 6000
      interval = setInterval(next, heroInterval)
    }

    function stop() {
      if (interval) {
        clearInterval(interval)
        interval = null
      }
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = parseInt(dot.dataset.heroDot, 10)
        if (!isNaN(idx) && idx !== current) showSlide(idx)
        start()
      })
    })

    if (heroBg) {
      heroBg.addEventListener('mouseenter', stop)
      heroBg.addEventListener('mouseleave', start)
    }

    start()


  }

  if (heroBg) {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const isLowEnd = (() => {
      const cores = navigator.hardwareConcurrency || 4
      const mem = (navigator as any).deviceMemory || 4
      return cores <= 2 || mem <= 2
    })()

    if (!prefersReduced && !isLowEnd) {
      let lastY = 0
      let lowFpsCount = 0
      let lastFrameTime = performance.now()

      const onLenisScroll = (lenis) => {
        const now = performance.now()
        const dt = now - lastFrameTime
        lastFrameTime = now
        if (dt > 50) {
          lowFpsCount++
          if (lowFpsCount > 10) {
            window.__lenis.off('scroll', onLenisScroll)
            heroBg.style.transform = ''
            return
          }
        } else {
          lowFpsCount = Math.max(0, lowFpsCount - 1)
        }

        const y = lenis.animatedScroll * 0.4
        if (Math.abs(y - lastY) < 1) return
        lastY = y
        heroBg.style.transform = `translate3d(0, ${y}px, 0)`
      }
      if (window.__lenis) {
        window.__lenis.on('scroll', onLenisScroll)
      }
    }
  }
</script>
