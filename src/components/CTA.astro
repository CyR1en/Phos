---
interface Props {
  heading: string;
  buttonText: string;
  body?: string;
  configPrefix: string;
  configButtonKey: string;
  centered?: boolean;
  href?: string;
}

const { heading, buttonText, body, configPrefix, configButtonKey, centered = false, href = '/contact' } = Astro.props
---

<section data-animate class="animate-reveal mx-auto max-w-7xl px-6 py-20 sm:px-6 lg:px-8">
  <div class:list={["rounded-lg bg-canvas-alt border border-border px-8 py-16 sm:px-16 sm:py-20 lg:py-20", { "text-center": centered }]}>
    <p class="font-mono text-xs uppercase tracking-wider text-muted">Contact</p>
    <h2 class="mt-4 font-display text-3xl sm:text-4xl text-ink" data-config={`${configPrefix}.heading`}>
      {heading}
    </h2>
    {body && (
      <p class="mt-6 text-lg text-ink/70 leading-relaxed" data-config={`${configPrefix}.body`}>
        {body}
      </p>
    )}
    <a
      href={href}
      class="mt-10 inline-flex items-center rounded-pill bg-primary text-canvas px-6 py-3 text-sm font-medium hover:opacity-90 transition-opacity"
    >
      <span data-config={`${configPrefix}.${configButtonKey}`}>{buttonText}</span>
      <svg class="ml-2 size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>
