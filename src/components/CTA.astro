---
import config from '@content/site-config.json'
---

<section data-animate class="animate-reveal mx-auto max-w-7xl px-4 py-6 sm:py-12 sm:px-6 lg:px-8">
  <div class="rounded-2xl bg-ink dark:bg-ink-dark px-6 py-6 sm:px-16 sm:py-16 text-center">
    <h2 class="text-3xl font-bold tracking-tight text-surface dark:text-surface-dark sm:text-4xl">
      {config.home.cta.heading}
    </h2>
    {config.home.cta.body && (
      <p class="mt-4 text-lg text-surface/70 dark:text-surface-dark/70">
        {config.home.cta.body}
      </p>
    )}
    <a
      href="/contact"
      class="mt-6 inline-block rounded-lg bg-white px-8 py-3 text-sm font-semibold text-black hover:bg-white/90 dark:bg-black dark:text-white transition-colors"
    >
      {config.home.cta.button}
    </a>
  </div>
</section>
